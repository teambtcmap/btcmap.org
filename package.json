{
	"name": "btcmap",
	"version": "1.0.0",
	"private": true,
	"description": "Find places to spend sats wherever you are.",
	"repository": "https://github.com/teambtcmap/btcmap.org",
	"author": "secondl1ght <secondl1ght@protonmail.com>",
	"license": "AGPL-3.0",
	"engines": {
		"node": ">=22"
	},
	"type": "module",
	"scripts": {
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"dev": "vite dev --host",
		"format": "biome check src",
		"format:fix": "biome format --write src",
		"lint": "biome check src",
		"lint:fix": "biome check --write src",
		"prepare": "husky",
		"preview": "vite preview",
		"test": "vitest",
		"typecheck": "tsc --project ./tsconfig.json --noEmit --pretty"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": [
			"biome check --write --no-errors-on-unmatched"
		],
		"*.{json,css}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@mapbox/geojson-rewind": "^0.5.2",
		"@nazka/map-gl-js-spiderfy": "^2.0.0",
		"@tanstack/match-sorter-utils": "^8.19.4",
		"@tanstack/svelte-table": "^8.21.3",
		"@turf/convex": "^7.3.5",
		"@turf/helpers": "^7.3.5",
		"@zerodevx/svelte-toast": "^0.9.6",
		"axios": "^1.15.0",
		"axios-retry": "^4.5.0",
		"chart.js": "^4.5.1",
		"d3-geo": "^3.1.1",
		"date-fns": "^4.3.0",
		"dompurify": "^3.4.8",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"i18n-iso-countries": "^7.14.0",
		"js-confetti": "^0.13.1",
		"localforage": "^1.10.0",
		"maplibre-gl": "^5.24.0",
		"marked": "^18.0.5",
		"opening_hours": "^3.13.0",
		"qrcode": "^1.5.4",
		"svelte-i18n": "^4.0.1",
		"svelte-outclick": "^3.7.1",
		"svelte-time": "^1.1.0",
		"svg-captcha": "^1.4.0",
		"tippy.js": "^6.3.7"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@iconify/svelte": "^4.2.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/kit": "^2.63.1",
		"@sveltejs/vite-plugin-svelte": "^3.1.2",
		"@tailwindcss/postcss": "^4.3.0",
		"@tailwindcss/vite": "^4.3.0",
		"@types/d3-geo": "^3.1.0",
		"@types/dompurify": "^3.2.0",
		"@types/geojson": "^7946.0.16",
		"@types/node": "^25.9.3",
		"@types/qrcode": "^1.5.6",
		"jsdom": "^29.0.2",
		"lint-staged": "^17.0.4",
		"postcss": "^8.5.10",
		"svelte": "^4.2.20",
		"svelte-check": "^4.6.0",
		"svelte-preprocess": "^6.0.3",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^5.4.21",
		"vitest": "^3.2.4"
	},
	"packageManager": "pnpm@10.11.0"
}
